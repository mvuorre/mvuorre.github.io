```{=html}
<ul class="list">
    <% items.forEach(item=> { %>
        <li class="list-item">
            <div class="listing-name">
                <% if (item.type==="journalArticle" ) { %>
                    <i class="fa-solid fa-graduation-cap"></i>
                    <% } else if (item.type==="videoRecording" ) { %>
                        <i class="fa-solid fa-film"></i>
                        <% } else if (item.type==="webpage" ) { %>
                            <i class="fa-solid fa-globe"></i>
                            <% } else if (item.type==="magazineArticle" ) { %>
                                <i class="fa-solid fa-newspaper"></i>
                                <% } else if (item.type==="blogPost" ) { %>
                                    <i class="fa-solid fa-pen"></i>
                                    <% } %>
                                        <a href="<%- item.url %>">
                                            <%= item.title %>
                                        </a>
            </div>
            <div class="listing-meta">
                <% if (item.authors) { %>
                    <div class="listing-authors"><strong>Authors:</strong>
                        <%= item.authors %>
                    </div>
                    <% } %>
                        <span class="listing-date">
                            <strong>Date:</strong>
                            <% if (item.date && !isNaN(new Date(item.date).getTime())) { %>
                                <%= new Date(item.date).toISOString().slice(0, 10) %>
                                    <% } else { %>
                                        Unknown
                                        <% } %>
                                            <% if (item.date_read && !isNaN(new Date(item.date_read).getTime())) { %>
                                                | <strong>Date read:</strong>
                                                <%= new Date(item.date_read).toISOString().slice(0, 10) %>
                                                    <% } %>
                                                        <% if (item.archive) { %>
                                                            <div class="listing-archive">
                                                                | <strong>Archive link:</strong> <a
                                                                    href="<%- item.archive %>"><%- item.archive %></a>
                                                            </div>
                                                            <% } %>
                        </span>
            </div>
            <% if (item.abstract) { %>
                <details>
                    <summary>Summary</summary>
                    <div class="listing-abstract">
                        <%= item.abstract %>
                    </div>
                </details>
                <% } %>
        </li>
        <% }); %>
</ul>

```
